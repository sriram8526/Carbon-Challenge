# EditorConfig — enforces consistent coding styles across all editors/IDEs
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
max_line_length = 100

[*.json]
indent_size = 2

[*.html]
indent_size = 2

[Makefile]
indent_style = tab
